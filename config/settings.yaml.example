# ============================================
# Spam Guard - Einstellungen (Vorlage)
# ============================================
# Kopieren und anpassen:
#   cp config/settings.yaml.example config/settings.yaml

# --------------------------------------------
# Filter: Welche E-Mails werden geprüft?
# --------------------------------------------
filter:
  # "count" = letzte X E-Mails pro Account
  # "days"  = E-Mails der letzten X Tage
  mode: "count"
  days_back: 7    # Tage zurück (bei mode: "days")
  limit: 50       # Anzahl E-Mails (bei mode: "count")

# --------------------------------------------
# LLM (Ollama) - Optional
# --------------------------------------------
llm:
  # false = kein Ollama nötig (~88-90% Genauigkeit, nur Bayesian)
  # true  = Ollama erforderlich (~94-96% Genauigkeit)
  #
  # ⚠️  WICHTIG: Damit LLM tatsächlich aufgerufen wird, müssen BEIDE Schalter aktiv sein:
  #   llm.enabled: true           ← aktiviert Ollama-Integration
  #   bayesian.llm_fallback: true ← lässt unsichere Mails zum LLM eskalieren
  #   (llm_fallback: false → unsichere Mails gehen direkt als HAM durch)
  enabled: false

  url: "http://localhost:11434"
  model: "gemma3:12b"   # ollama list → zeigt verfügbare Modelle

  timeouts:
    inference: 120      # Max. Wartezeit für eine LLM-Anfrage (Sekunden)
    warmup: 60          # Max. Wartezeit beim ersten Modell-Start
    availability: 3     # Timeout beim Erreichbarkeits-Check

  inference:
    temperature: 0.1    # 0.0 = deterministisch, 1.0 = kreativ
    num_predict: 80     # Max. generierte Token pro Antwort (3-Zeilen-Format braucht ~50)

# --------------------------------------------
# Diagnose & Debugging
# --------------------------------------------
# ⚠️  Nur für Tests — nicht für den Produktionsbetrieb geeignet.
# Dokumentation: docs/LLM.md → Abschnitt "Diagnose & Debugging"
llm_diagnostics:
  # Force-Modus: LLM läuft für JEDE Mail (Bayesian gibt keinen frühen Exit mehr).
  # Negiert den Effizienzgewinn des Bayesian-Filters — Durchsatz ~15-25 Mails/min.
  # Sinnvoll zum Prüfen ob Ollama + Modell korrekt antworten.
  # Nach dem Test: auf false setzen und bayesian.llm_fallback: true für Produktion nutzen.
  force: false

  # Bayesian-Score als Kontext-Hint in den LLM-User-Prompt einfügen.
  # Nur wirksam wenn force: true. System-Prompt bleibt davon unberührt.
  use_bayesian_score: true

# --------------------------------------------
# Bayesian Filter
# --------------------------------------------
bayesian:
  enabled: true

  # false = Unsichere Mails → HAM (schnell, vermeidet False Positives)
  # true  = Unsichere Mails → LLM (genauer, erfordert llm.enabled: true)
  llm_fallback: false

  thresholds:
    hard_ham: 0.3    # Score < 0.3 → HAM (Auto-deliver)
    hard_spam: 0.5   # Score > 0.5 → SPAM (Auto-block)
    # Dazwischen → HAM oder LLM (je nach llm_fallback)

  model_path: "data/models/bayesian_model.pkl"
  vectorizer_path: "data/models/vectorizer.pkl"

  training:
    min_samples_warning: 100   # Warnung bei < 100 Mails pro Kategorie
    feature_count: 5000        # TF-IDF max features
    cv_folds_min: 2
    cv_folds_max: 5

  newsletter:
    # "ham"    = Newsletter → Posteingang
    # "folder" = Newsletter → separater Ordner (empfohlen)
    # "spam"   = Newsletter → Spam-Ordner
    routing: "ham"
    folder: "Newsletter"   # Ordner muss im E-Mail-Client existieren

# --------------------------------------------
# Auto-Training
# --------------------------------------------
auto_training:
  enabled: true

  # Maximale Anzahl automatisch gesammelter Spam-Samples (älteste werden gelöscht)
  # Manuelle Samples in data/training/spam/ bleiben unangetastet
  max_spam_samples: 500

  # Re-Training nach X neuen Samples (passiert am Ende des Filter-Laufs)
  # false = Samples werden gesammelt, aber kein automatisches Re-Training
  retrain_every: 50
