# ========================================
# Ollama Spam Guard - Git Ignore
# ========================================

# Environment & Credentials (NIEMALS committen!)
.env
.env.*
!.env.example
accounts.yaml
!accounts.yaml.example

# User-spezifische Listen (persönliche Daten!)
data/lists/whitelist.txt
data/lists/blacklist.txt
data/lists/blacklist_sources.yaml
!data/lists/whitelist.txt.example
!data/lists/blacklist.txt.example
!data/lists/blacklist_sources.yaml.example

# Externe Listen Cache
data/lists/external/
!data/lists/external/.gitkeep

# Python Runtime
__pycache__/
*.py[cod]
*$py.class
.Python

# Virtual Environment
.venv/

# Logs & Output
*.log
spam_filter.log

# Benchmark Results (nur README behalten)
benchmark/*
!benchmark/README.md

# IDE & Editors
.vscode/
.idea/
*.swp
*.swo
*~

# macOS
.DS_Store
.AppleDouble
.LSOverride
*.command

# macOS App Bundle
*.app/

# Testing
.pytest_cache/
.coverage
htmlcov/

# Temp Files
*.tmp
*.bak
*.orig
